---
const { items = [] } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",

  mainEntity: items.map((item) => ({

    "@type": "Question",

    name: item.question,

    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer
    }

  }))
};
---

<section class="py-24 border-t border-white/10">

  <div class="container-custom max-w-4xl">

    <div class="mb-16">

      <p class="uppercase tracking-[0.35em] text-xs text-gray-500 mb-6">
        FAQ
      </p>

      <h2 class="text-4xl md:text-5xl font-bold tracking-tight">
        Frequently Asked Questions
      </h2>

    </div>

    <div class="space-y-10">

      {items.map((item) => (

        <div class="border border-white/10 rounded-3xl p-8">

          <h3 class="text-2xl font-semibold mb-4">
            {item.question}
          </h3>

          <p class="text-gray-400 leading-relaxed">
            {item.answer}
          </p>

        </div>

      ))}

    </div>

  </div>

</section>

<script
  type="application/ld+json"
  set:html={JSON.stringify(schema)}
></script>