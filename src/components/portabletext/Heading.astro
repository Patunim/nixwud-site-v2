---
import slugify from "slugify";

const { node } = Astro.props;

const style = node?.style || "h2";

const text =
  node?.children
    ?.map((child) => child.text || "")
    .join(" ") || "";

const slug = slugify(text, {
  lower: true,
  strict: true,
});
---

{
  style === "h2" && (

    <h2
      id={slug}
      data-heading
      class="scroll-mt-32 text-4xl font-bold mt-16 mb-8"
    >
      {text}
    </h2>

  )
}

{
  style === "h3" && (

    <h3
      id={slug}
      data-heading
      class="scroll-mt-32 text-3xl font-semibold mt-12 mb-6"
    >
      {text}
    </h3>

  )
}