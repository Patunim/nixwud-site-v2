---
const {
  summary
} = Astro.props;
---

<section class="border border-white/10 rounded-3xl p-10 mb-16 bg-white/[0.02]">

  <p class="uppercase tracking-[0.35em] text-xs text-gray-500 mb-6">
    ARTICLE SUMMARY
  </p>

  <p class="text-2xl leading-relaxed text-gray-300">
    {summary}
  </p>

</section>