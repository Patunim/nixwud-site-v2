---
const {
  relatedTopics = [],
  prerequisiteTopics = [],
  advancedTopics = []
} = Astro.props;
---

<section class="py-24 border-t border-white/10">

  <div class="container-custom">

    <div class="max-w-5xl">

      <p class="uppercase tracking-[0.35em] text-xs text-gray-500 mb-6">
        KNOWLEDGE GRAPH
      </p>

      <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-16">
        Related concepts and learning paths
      </h2>

      <div class="grid md:grid-cols-3 gap-10">

        <!-- Prerequisites -->

        <div>

          <h3 class="text-2xl font-semibold mb-6">
            Prerequisites
          </h3>

          <div class="space-y-4">

            {prerequisiteTopics.map((topic) => (

              <a
                href={topic.url}
                class="block border border-white/10 rounded-2xl p-5 hover:border-white/20 transition"
              >
                {topic.title}
              </a>

            ))}

          </div>

        </div>

        <!-- Related -->

        <div>

          <h3 class="text-2xl font-semibold mb-6">
            Related Topics
          </h3>

          <div class="space-y-4">

            {relatedTopics.map((topic) => (

              <a
                href={topic.url}
                class="block border border-white/10 rounded-2xl p-5 hover:border-white/20 transition"
              >
                {topic.title}
              </a>

            ))}

          </div>

        </div>

        <!-- Advanced -->

        <div>

          <h3 class="text-2xl font-semibold mb-6">
            Advanced Topics
          </h3>

          <div class="space-y-4">

            {advancedTopics.map((topic) => (

              <a
                href={topic.url}
                class="block border border-white/10 rounded-2xl p-5 hover:border-white/20 transition"
              >
                {topic.title}
              </a>

            ))}

          </div>

        </div>

      </div>

    </div>

  </div>

</section>