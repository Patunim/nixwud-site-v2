---
import Layout from "../layouts/Layout.astro";
---

<Layout>

  <section class="py-32 border-b border-white/10">

    <div class="container-custom">

      <div class="max-w-4xl">

        <p class="uppercase tracking-[0.35em] text-xs text-gray-500 mb-6">
          CONTACT
        </p>

        <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-8">
          Let’s build something modern.
        </h1>

        <p class="text-xl text-gray-400 leading-relaxed">
          Reach out to discuss your project, digital strategy, or website needs.
        </p>

      </div>

    </div>

  </section>

  <section class="py-32">

    <div class="container-custom max-w-3xl">

      <form class="space-y-8">

        <div>

          <label class="block mb-3 text-sm text-gray-400">
            Name
          </label>

          <input
            type="text"
            class="w-full bg-transparent border border-white/10 rounded-xl px-5 py-4 outline-none focus:border-white/30"
          />

        </div>

        <div>

          <label class="block mb-3 text-sm text-gray-400">
            Email
          </label>

          <input
            type="email"
            class="w-full bg-transparent border border-white/10 rounded-xl px-5 py-4 outline-none focus:border-white/30"
          />

        </div>

        <div>

          <label class="block mb-3 text-sm text-gray-400">
            Message
          </label>

          <textarea
            rows="6"
            class="w-full bg-transparent border border-white/10 rounded-xl px-5 py-4 outline-none focus:border-white/30"
          ></textarea>

        </div>

        <button
          class="bg-white text-black px-8 py-4 rounded-xl font-medium hover:bg-gray-200 transition"
        >
          Send Message
        </button>

      </form>

    </div>

  </section>

</Layout>