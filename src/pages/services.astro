---
import Layout from "../layouts/Layout.astro";
import FAQ from "../components/FAQ.astro";
---

<Layout>

  <section class="py-32 border-b border-white/10">

    <div class="container-custom">

      <div class="max-w-4xl">

        <p class="uppercase tracking-[0.35em] text-xs text-gray-500 mb-6">
          SERVICES
        </p>

        <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-8">
          Modern digital systems built for performance.
        </h1>

        <p class="text-xl text-gray-400 leading-relaxed">
          We help businesses build scalable websites, SEO systems, and high-performance digital infrastructure.
        </p>

      </div>

    </div>

  </section>

  <section class="py-32">

    <div class="container-custom grid md:grid-cols-2 gap-10">

      <div class="border border-white/10 rounded-3xl p-10">

        <h2 class="text-3xl font-semibold mb-6">
          Web Development
        </h2>

        <p class="text-gray-400 leading-relaxed">
          Modern frontend architecture, responsive systems, and scalable digital platforms built for speed and usability.
        </p>

      </div>

      <div class="border border-white/10 rounded-3xl p-10">

        <h2 class="text-3xl font-semibold mb-6">
          SEO Strategy
        </h2>

        <p class="text-gray-400 leading-relaxed">
          Technical SEO optimization, structured content systems, metadata architecture, and search-focused performance.
        </p>

      </div>

    </div>

  </section>

  <FAQ />

</Layout>