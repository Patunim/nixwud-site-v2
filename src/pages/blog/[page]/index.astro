---
import Layout from "../../../layouts/Layout.astro";
import { client, urlFor } from "../../../lib/sanity";

export async function getStaticPaths({ paginate }) {

  const posts = await client.fetch(`
    *[_type == "post"] | order(publishedAt desc){

      title,
      slug,
      publishedAt,
      excerpt,
      mainImage

    }
  `);

  return paginate(posts, {
    pageSize: 6
  });
}

const { page } = Astro.props;
---

<Layout
  title="Blog — Nixwud"
  description="Insights, strategies and modern digital systems."
  url={`https://nixwud.com/blog/${page.currentPage}`}
>

  <section class="py-32">

    <div class="container-custom">

      <div class="mb-20">

        <input
          id="search-input"
          type="text"
          placeholder="Search articles..."
          class="w-full bg-transparent border border-white/10 rounded-2xl px-6 py-5 text-lg outline-none focus:border-white/30 transition"
        />

      </div>

      <!-- SEARCH RESULTS -->

      <div
        id="search-results"
        class="grid gap-10 mb-20"
      ></div>

      <!-- NORMAL PAGINATED POSTS -->

      <div
        id="default-posts"
        class="grid gap-10"
      >

        {page.data.map((post) => (

          <article class="border border-white/10 rounded-3xl overflow-hidden hover:border-white/20 transition">

            {
              post.mainImage && (

                <img
                  src={urlFor(post.mainImage)
                    .width(1200)
                    .format("webp")
                    .url()}
                  alt={post.title}
                  class="w-full aspect-[16/9] object-cover"
                  loading="lazy"
                />

              )
            }

            <div class="p-10">

              <p class="text-sm text-gray-500 mb-5">
                {new Date(post.publishedAt).toDateString()}
              </p>

              <h2 class="text-3xl font-semibold mb-5">
                {post.title}
              </h2>

              <p class="text-gray-400 leading-relaxed mb-8">
                {post.excerpt}
              </p>

              <a
                href={`/blog/${post.slug.current}`}
                class="text-white"
              >
                Read Article →
              </a>

            </div>

          </article>

        ))}

      </div>

      <!-- PAGINATION -->

      <div
        id="pagination"
        class="flex gap-6 mt-20"
      >

        {
          page.url.prev && (

            <a
              href={page.url.prev}
              class="border border-white/10 px-6 py-3 rounded-full hover:border-white/20 transition"
            >
              Previous
            </a>

          )
        }

        {
          page.url.next && (

            <a
              href={page.url.next}
              class="border border-white/10 px-6 py-3 rounded-full hover:border-white/20 transition"
            >
              Next
            </a>

          )
        }

      </div>

    </div>

  </section>

  <script>

    const input =
      document.getElementById("search-input");

    const resultsContainer =
      document.getElementById("search-results");

    const defaultPosts =
      document.getElementById("default-posts");

    const pagination =
      document.getElementById("pagination");

    let posts = [];

    async function loadPosts() {

      const response =
        await fetch("/search.json");

      posts = await response.json();
    }

    function renderSearchResults(query) {

      const cleanedQuery =
        query.trim().toLowerCase();

      if (!cleanedQuery) {

        resultsContainer.innerHTML = "";

        defaultPosts.style.display = "grid";

        pagination.style.display = "flex";

        return;
      }

      defaultPosts.style.display = "none";

      pagination.style.display = "none";

      const filtered = posts.filter((post) => {

        const title =
          (post.title || "")
            .toLowerCase();

        const excerpt =
          (post.excerpt || "")
            .toLowerCase();

        return (
          title.includes(cleanedQuery) ||
          excerpt.includes(cleanedQuery)
        );
      });

      if (filtered.length === 0) {

        resultsContainer.innerHTML = `
          <p class="text-gray-400">
            No articles found.
          </p>
        `;

        return;
      }

      resultsContainer.innerHTML =
        filtered.map((post) => `

          <article class="border border-white/10 rounded-3xl p-10">

            <h2 class="text-3xl font-semibold mb-5">
              ${post.title}
            </h2>

            <p class="text-gray-400 leading-relaxed mb-8">
              ${post.excerpt || ""}
            </p>

            <a
              href="/blog/${post.slug.current}"
              class="text-white"
            >
              Read Article →
            </a>

          </article>

        `).join("");
    }

    async function initializeSearch() {

      await loadPosts();

      input.addEventListener("input", (e) => {

        renderSearchResults(e.target.value);

      });
    }

    initializeSearch();

  </script>

</Layout>